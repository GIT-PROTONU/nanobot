# pixi
.pixi/
*.lock

# colcon
/build/
/install/
/log/

# PlatformIO build cache (firmware) — incl. the abandoned esp32_coprocessor leftovers
.pio/
firmware/esp32_coprocessor/

# rust
src/lds_driver/target/
**/*.rs.bk

# python
__pycache__/
*.pyc
*.egg-info/

# editor
.vscode/
.idea/

# local SBC credentials (never commit)
.nano-deploy.env
.nano-askpass.sh

# local OpenRouter key for the dev web UI (never commit)
scripts/.openrouter_key

# dev web UI (scripts/dev_webui.py) runtime state — the "soul" + logs + goal/reward state.
# Volatile + drifts, so kept out of git; the folder stays (see devstate/.gitkeep). To version
# a hand-made personality anyway: git add -f devstate/personality.json
/devstate/*
!/devstate/.gitkeep
